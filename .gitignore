# ============================================
# Master Class — Root .gitignore
# ============================================

# --- Environment & Secrets ---
.env*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# --- Node.js / Next.js ---
node_modules/
.next/
out/
.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Testing ---
coverage/
.coverage
htmlcov/
.pytest_cache/

# --- Misc ---
*.pem
*.log
